VLESS_UUID=
REALITY_PUBLIC_KEY=
REALITY_SHORT_ID=
REALITY_SNI=
SS_CLIENT_PASSWORD=
SHADOWTLS_PASSWORD=
SHADOWTLS_SNI=
CDN_IP=
CDN_DOMAIN=
# CDN_UUID 可选，不设置时使用 VLESS_UUID
