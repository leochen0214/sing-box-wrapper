#!/bin/bash
# sb - sing-box 模式切换启动器
# 用法：sb [-c config_file] [mixed|tun|claude|stop|status|...]
#
#   mixed  (默认) - 绕过大陆IP，系统代理 127.0.0.1:<port>（端口从 config.json 读取）
#   tun            - 绕过大陆IP，TUN 全局接管（需要 root）
#   claude         - 仅 Claude 域名走代理，其余直连（公司网络用）

set -euo pipefail

# 跟随 symlink 解析真实脚本目录
_SELF="$0"
if [ -L "$_SELF" ]; then
    _TARGET="$(readlink "$_SELF")"
    [[ "$_TARGET" != /* ]] && _TARGET="$(dirname "$_SELF")/$_TARGET"
    _SELF="$_TARGET"
fi
DIR="$(cd "$(dirname "$_SELF")" && pwd)"
BASE_CONFIG="$DIR/config.json"
RUN_CONFIG="$DIR/.config-run.json"
PID_FILE="$DIR/.sing-box.pid"
MODE_FILE="$DIR/.current-mode"
CLAUDE_DOMAINS_FILE="$DIR/proxy-domains.txt"
CORP_BYPASS_FILE="$DIR/corp-bypass-domains.txt"

# 解析 -c 参数（指定配置文件）
_CONFIG_FLAG=()
while getopts "c:" opt; do
    case $opt in
        c)
            if [[ "$OPTARG" = /* ]]; then
                BASE_CONFIG="$OPTARG"
            else
                BASE_CONFIG="$PWD/$OPTARG"
            fi
            _CONFIG_FLAG=("-c" "$BASE_CONFIG")
            ;;
        *) echo "用法: sb [-c config_file] [command]"; exit 1 ;;
    esac
done
shift $((OPTIND - 1))

# ── helpers ─────────────────────────────────────────────────────────
lib() { python3 "$DIR/lib.py" "$@"; }

current_pid()  { [ -f "$PID_FILE" ] && cat "$PID_FILE"; }
current_mode() { [ -f "$MODE_FILE" ] && cat "$MODE_FILE"; }

# ps -p 能跨 UID 检测进程存在；kill -0 对 root 进程从用户态会返回 EPERM 被误判为不存在
pid_alive() { [ -n "$1" ] && ps -p "$1" >/dev/null 2>&1; }

# 精确名字匹配，排除 'sudo sing-box ...' 这类命令行包含 sing-box 的父进程
sing_box_pid() { pgrep -x sing-box 2>/dev/null | head -1; }

# 先看 PID 文件（记录的是我们这次启动的进程）；若不准，兜底到 pgrep，避免漏检孤儿进程
is_running() {
    local pid
    pid=$(current_pid)
    pid_alive "$pid" && return 0
    pid=$(sing_box_pid)
    [ -n "$pid" ]
}

mode_is_proxy() {
    local m; m=$(current_mode)
    [ "$m" = "mixed" ] || [ "$m" = "claude" ]
}

# 这些子命令不需要加载 config.json / 端口
config_free_cmd() {
    case "${1:-}" in init|import|export|serve|sub) return 0;; *) return 1;; esac
}

# sing-box 运行时打印 "-x http://127.0.0.1:PORT"；否则空
curl_proxy_arg() {
    is_running || return 0
    local port
    port=$(awk '/"type": "mixed"/{f=1} f && /listen_port/{gsub(/[^0-9]/,"");print;exit}' "$BASE_CONFIG" 2>/dev/null)
    [ -n "$port" ] && echo "-x http://127.0.0.1:$port"
}

# 输入为 1..99 → 读 cdn-ips.txt 第 N 行第 1 列；否则原样返回
resolve_cdn_target() {
    local input="$1" line
    if [[ "$input" =~ ^[0-9]+$ ]] && [ "$input" -le 99 ]; then
        line=$(sed -n "${input}p" "$CDN_IPS_FILE" 2>/dev/null)
        [ -n "$line" ] && input=$(awk '{print $1}' <<<"$line")
    fi
    echo "$input"
}

# 配置文件不存在时提示 init（init 命令本身不需要 config.json）
if [ ! -f "$BASE_CONFIG" ] && ! config_free_cmd "${1:-}"; then
    if [ -f "$DIR/config.template.json" ]; then
        echo "Error: $(basename "$BASE_CONFIG") 不存在"
        echo "运行 'sb init' 从模板生成配置"
    else
        echo "Error: $(basename "$BASE_CONFIG") 不存在"
    fi
    exit 1
fi

# init/import 等不需要读取配置和端口信息
if ! config_free_cmd "${1:-}"; then
    PROXY_PORT=$(awk '/"type": "mixed"/{found=1} found && /listen_port/{gsub(/[^0-9]/,""); print; exit}' "$BASE_CONFIG")
    DEFAULT_IFACE=$(route -n get default 2>/dev/null | awk '/interface:/{print $2}')
    [ ${#_CONFIG_FLAG[@]} -gt 0 ] && echo "配置文件: $(basename "$BASE_CONFIG")"
    [ -n "$PROXY_PORT" ] && echo "代理端口: $PROXY_PORT, 默认接口: $DEFAULT_IFACE"
fi

enable_system_proxy() {
    networksetup -setwebproxy Wi-Fi 127.0.0.1 "$PROXY_PORT"
    networksetup -setsecurewebproxy Wi-Fi 127.0.0.1 "$PROXY_PORT"
    if [ -f "$CORP_BYPASS_FILE" ]; then
        local -a domains_arr
        mapfile -t domains_arr < <(grep -v '^#' "$CORP_BYPASS_FILE" | grep -v '^$')
        if [ ${#domains_arr[@]} -gt 0 ]; then
            networksetup -setproxybypassdomains Wi-Fi "${domains_arr[@]}"
        fi
    fi
    echo "系统代理已开启 (127.0.0.1:$PROXY_PORT)"
}

disable_system_proxy() {
    networksetup -setwebproxystate Wi-Fi off
    networksetup -setsecurewebproxystate Wi-Fi off
    networksetup -setproxybypassdomains Wi-Fi ""
    echo "系统代理已关闭"
}

stop_singbox() {
    # PID 文件不可信（terminal 挂断或重入场景下可能过期）；pgrep 才是真相
    local pid
    pid=$(current_pid)
    pid_alive "$pid" || pid=$(sing_box_pid)
    if [ -n "$pid" ] && pid_alive "$pid"; then
        # 如果进程属于 root（TUN 模式下的 sudo sing-box），自动 sudo
        local is_root=false
        [ "$(ps -o uid= -p "$pid" 2>/dev/null | tr -d ' ')" = "0" ] && is_root=true
        $is_root && sudo -v
        echo "停止 sing-box (PID $pid)..."
        if $is_root; then
            sudo kill "$pid" 2>/dev/null || true
        else
            kill "$pid" 2>/dev/null || true
        fi
        while pid_alive "$pid"; do sleep 0.2; done
    fi
    rm -f "$PID_FILE"
}

show_status() {
    if is_running; then
        local pid mode
        pid=$(current_pid)
        mode=$(current_mode)
        echo "sing-box 运行中 (PID $pid, 模式 ${mode:-?})"
    else
        # 不在这里 rm PID 文件：可能是 kill -0 对跨 UID 进程的误判，删了反而掩盖问题
        # 真正的清理发生在 stop_singbox / mode 切换路径
        echo "sing-box 未运行"
    fi
}

CMD="${1:-mixed}"

# sb init 子命令：从模板 + .env 生成配置
_sb_init() {
    local profile="${1:-}"
    local env_file tpl out

    if [ -n "$profile" ]; then
        env_file="$PWD/.env.${profile}"
        out="$PWD/config-${profile}.json"
    else
        env_file="$PWD/.env"
        out="$PWD/config.json"
    fi
    tpl="$DIR/config.template.json"

    if [ ! -f "$env_file" ]; then
        echo "Error: $env_file 不存在"
        echo "可用的 .env 文件："
        ls -1 "$DIR"/.env.* 2>/dev/null | sed 's/.*\/.env\./  sb init /'
        exit 1
    fi
    if [ ! -f "$tpl" ]; then
        echo "Error: 模板 $tpl 不存在"
        exit 1
    fi

    lib init-config "$env_file" "$tpl" "$out"

    if sing-box check -c "$out" 2>/dev/null; then
        echo "$(basename "$out") 已生成（配置验证通过）"
    else
        echo "$(basename "$out") 已生成，但配置验证失败："
        sing-box check -c "$out" 2>&1
        exit 1
    fi
}

case "$CMD" in
    init)
        _sb_init "${2:-}"
        exit 0
        ;;
    import)
        profile="${2:-}"
        ssh_host=""
        if [ -n "$profile" ] && [ "${3:-}" = "--ssh" ]; then
            ssh_host="${4:-}"
        elif [ "${2:-}" = "--ssh" ]; then
            ssh_host="${3:-}"
            profile=""
        fi
        if [ -n "$profile" ]; then
            env_file="$PWD/.env.${profile}"
        else
            env_file="$PWD/.env"
        fi
        if [ ! -f "$env_file" ]; then
            if [ -n "$ssh_host" ]; then
                vps_ip=$(ssh -G "$ssh_host" 2>/dev/null | awk '/^hostname /{print $2}')
                [ -z "$vps_ip" ] && vps_ip="$ssh_host"
                echo "自动创建 $env_file (VPS_IP=$vps_ip)"
                echo "VPS_IP=${vps_ip}" > "$env_file"
            else
                echo "Error: $env_file 不存在，请先创建并填写 VPS_IP"
                echo ""
                echo "用法: sb import [name] [--ssh <alias>]"
                echo "  sb import              # 读取 .env 中的 VPS_IP"
                echo "  sb import dmit         # 读取 .env.dmit 中的 VPS_IP"
                echo "  sb import --ssh dmit   # 读取 .env，用 SSH alias 连接"
                exit 1
            fi
        fi
        vps_ip=$(grep '^VPS_IP=' "$env_file" | head -1 | cut -d= -f2)
        if [ -z "$vps_ip" ] && [ -n "$ssh_host" ]; then
            vps_ip=$(ssh -G "$ssh_host" 2>/dev/null | awk '/^hostname /{print $2}')
            [ -z "$vps_ip" ] && vps_ip="$ssh_host"
        elif [ -z "$vps_ip" ]; then
            echo "Error: $env_file 中未找到 VPS_IP"
            exit 1
        fi
        if [ -n "$ssh_host" ]; then
            ssh_target="$ssh_host"
        else
            ssh_target="root@$vps_ip"
        fi
        echo "从 $ssh_target 提取 s-ui 凭据..."
        if ! credentials=$(lib remote-import-script | ssh "$ssh_target" "python3 -"); then
            echo "Error: SSH 连接或数据库读取失败"
            exit 1
        fi
        cdn_ip=$(grep '^CDN_IP=' "$env_file" 2>/dev/null | head -1 | cut -d= -f2 || true)
        cdn_ip="${cdn_ip:-141.101.114.1}"
        existing_cdn_domain=$(grep '^CDN_DOMAIN=' "$env_file" 2>/dev/null | head -1 | cut -d= -f2 || true)
        extracted_cdn_domain=$(echo "$credentials" | grep '^CDN_DOMAIN=' | head -1 | cut -d= -f2)
        cdn_domain="${extracted_cdn_domain:-$existing_cdn_domain}"
        credentials=$(echo "$credentials" | grep -v '^CDN_DOMAIN=')
        {
            echo "# ${profile} VPS (${vps_ip})"
            echo "VPS_IP=${vps_ip}"
            echo "$credentials"
            echo "CDN_IP=${cdn_ip}"
            echo "CDN_DOMAIN=${cdn_domain}"
        } > "$env_file"
        echo ""
        echo "已写入 $env_file:"
        sed 's/^/  /' "$env_file"
        echo ""
        echo "下一步: sb init${profile:+ $profile}"
        exit 0
        ;;
    stop)
        if mode_is_proxy; then
            disable_system_proxy
        fi
        stop_singbox
        rm -f "$MODE_FILE"
        echo "已停止"
        exit 0
        ;;
    status)
        show_status
        exit 0
        ;;
    log)
        level="${2:-}"
        case "$level" in
            info|warn|error|debug) ;;
            *)
                echo "当前日志级别: $(lib log-get "$BASE_CONFIG")"
                echo "用法: sb log [info|warn|error|debug]"
                exit 0
                ;;
        esac
        lib log-set "$BASE_CONFIG" "$level"
        echo "日志级别已改为: $level"
        if is_running && [ -f "$MODE_FILE" ]; then
            mode=$(current_mode)
            echo "重启 $mode 模式以生效..."
            exec "$0" "${_CONFIG_FLAG[@]}" "$mode"
        else
            echo "sing-box 未运行，下次启动时生效"
        fi
        exit 0
        ;;
    cdn)
        action="${2:-}"
        CDN_IPS_FILE="$DIR/cdn-ips.txt"
        CFST="$DIR/cfst"
        # 读取当前 proxy-cdn IP 和域名
        IFS=' ' read -r _cdn_current_ip _cdn_domain < <(lib cdn-current "$BASE_CONFIG")

        # 测试单个 IP 的 WebSocket 连通性，输出 "HTTP状态码 耗时秒"
        _cdn_test_ip() {
            curl -s -o /dev/null -w "%{http_code} %{time_total}" \
                --resolve "$_cdn_domain:443:$1" \
                --noproxy '*' --max-time 5 \
                -H "Upgrade: websocket" -H "Connection: Upgrade" \
                -H "Sec-WebSocket-Key: dGhlIHNhbXBsZSBub25jZQ==" \
                -H "Sec-WebSocket-Version: 13" \
                "https://$_cdn_domain/ws" 2>/dev/null || echo "000 99.000"
        }
        # 并行测试所有 IP，结果保存到 cdn-ips.txt，最优 IP 写入 stdout
        _cdn_test_all() {
            # 优先使用 CloudflareSpeedTest（覆盖更多 IP，更精准）
            if [ -x "$CFST" ]; then
                echo "使用 CloudflareSpeedTest 测速..." >&2
                local tmp_csv
                tmp_csv=$(mktemp /tmp/cfst.XXXXXX)
                ( cd "$DIR" && "$CFST" -url "https://$_cdn_domain/ws" -tl 300 -sl 0 -n 200 -t 4 -p 10 -o "$tmp_csv" ) >&2 2>&1
                : > "$CDN_IPS_FILE"
                local best_ip="" best_ms=99999
                while IFS=',' read -r ip sent recv loss delay speed; do
                    [ "$ip" = "IP 地址" ] || [ "$ip" = "IP" ] && continue
                    [ -z "$ip" ] && continue
                    local ms
                    ms=$(printf "%.0f" "$delay" 2>/dev/null)
                    [ -z "$ms" ] || [ "$ms" -le 0 ] 2>/dev/null && continue
                    printf "  %-18s ✓  %dms\n" "$ip" "$ms" >&2
                    echo "$ip $ms" >> "$CDN_IPS_FILE"
                    if [ "$ms" -lt "$best_ms" ]; then
                        best_ip="$ip"; best_ms="$ms"
                    fi
                done < "$tmp_csv"
                rm -f "$tmp_csv"
                sort -t' ' -k2 -n -o "$CDN_IPS_FILE" "$CDN_IPS_FILE"
                [ -n "$best_ip" ] && echo "$best_ip $best_ms"
                return 0
            fi
            # Fallback：curl 方式测试（仅 ~16 个 IP）
            local cf_ips tmp_dir
            echo "获取 Cloudflare IP 列表..." >&2
            cf_ips=$(lib cdn-fetch-ips)
            case " $cf_ips " in
                *" $_cdn_current_ip "*) ;;
                *) cf_ips="$_cdn_current_ip $cf_ips" ;;
            esac
            echo "测试 $(echo "$cf_ips" | wc -w | tr -d ' ') 个 IP 延迟...（安装 cfst 可测更多 IP: sb cdn install）" >&2
            tmp_dir=$(mktemp -d)
            for ip in $cf_ips; do
                ( _cdn_test_ip "$ip" > "$tmp_dir/$ip" ) &
            done
            wait
            : > "$CDN_IPS_FILE"
            local best_ip="" best_ms=99999
            for ip in $cf_ips; do
                [ -f "$tmp_dir/$ip" ] || continue
                read -r code t < "$tmp_dir/$ip"
                local ms
                ms=$(awk "BEGIN{printf \"%d\", $t * 1000}")
                if [ "$code" != "000" ]; then
                    printf "  %-18s ✓  %dms\n" "$ip" "$ms" >&2
                    echo "$ip $ms" >> "$CDN_IPS_FILE"
                    if [ "$ms" -lt "$best_ms" ]; then
                        best_ip="$ip"; best_ms="$ms"
                    fi
                else
                    printf "  %-18s ✗\n" "$ip" >&2
                fi
            done
            rm -rf "$tmp_dir"
            sort -t' ' -k2 -n -o "$CDN_IPS_FILE" "$CDN_IPS_FILE"
            [ -n "$best_ip" ] && echo "$best_ip $best_ms"
        }

        if [ "$action" = "install" ]; then
            if [ -x "$CFST" ]; then
                echo "CloudflareSpeedTest 已安装: $CFST"
                "$CFST" -v 2>&1 | head -1
                exit 0
            fi
            arch=$(uname -m)
            case "$arch" in
                arm64|aarch64) cfst_arch="arm64" ;;
                x86_64|amd64) cfst_arch="amd64" ;;
                *) echo "不支持的架构: $arch"; exit 1 ;;
            esac
            cfst_url="https://github.com/XIU2/CloudflareSpeedTest/releases/download/v2.3.4/cfst_darwin_${cfst_arch}.zip"
            echo "下载 CloudflareSpeedTest (darwin/$cfst_arch)..."
            curl -fLo /tmp/cfst.zip "$cfst_url" || { echo "下载失败"; exit 1; }
            unzip -o /tmp/cfst.zip cfst -d "$DIR" >/dev/null
            chmod +x "$CFST"
            rm -f /tmp/cfst.zip
            echo "已安装: $CFST"
            "$CFST" -v 2>&1 | head -1
            exit 0
        fi
        if [ "$action" = "ip" ]; then
            echo "当前 CDN IP: $_cdn_current_ip"
            result=$(_cdn_test_all)
            best_ip=$(echo "$result" | awk '{print $1}')
            best_ms=$(echo "$result" | awk '{print $2}')
            if [ -z "$best_ip" ]; then
                echo "所有 IP 均不可用"
                exit 1
            fi
            count=$(wc -l < "$CDN_IPS_FILE" | tr -d ' ')
            echo "已保存 $count 个可用 IP → cdn-ips.txt"
            cur_ms=$(awk -v ip="$_cdn_current_ip" '$1==ip{print $2}' "$CDN_IPS_FILE")
            if [ -z "$cur_ms" ]; then
                echo "当前 $_cdn_current_ip 不可用！"
                lib cdn-set-ip "$BASE_CONFIG" "$best_ip"
                echo "已切换: $_cdn_current_ip → $best_ip (${best_ms}ms)"
            elif [ "$best_ip" = "$_cdn_current_ip" ]; then
                echo "当前 $_cdn_current_ip 已是最优 (${cur_ms}ms)"
            else
                echo "当前: $_cdn_current_ip (${cur_ms}ms)  最优: $best_ip (${best_ms}ms)"
            fi
            exit 0
        fi
        if [ "$action" = "list" ]; then
            if [ ! -f "$CDN_IPS_FILE" ] || [ ! -s "$CDN_IPS_FILE" ]; then
                echo "无保存的 IP，先运行: sb cdn ip"
                exit 1
            fi
            echo "当前: $_cdn_current_ip"
            echo "可用 IP（按延迟排序）:"
            i=1
            while read -r ip ms; do
                mark=""
                [ "$ip" = "$_cdn_current_ip" ] && mark=" ←"
                printf "  %d) %-18s %sms%s\n" "$i" "$ip" "$ms" "$mark"
                i=$((i + 1))
            done < "$CDN_IPS_FILE"
            exit 0
        fi
        if [ "$action" = "set" ]; then
            target="${3:-}"
            if [ -z "$target" ]; then
                echo "用法: sb cdn set <IP 或序号>"
                exit 1
            fi
            target=$(resolve_cdn_target "$target")
            if [ "$target" = "$_cdn_current_ip" ]; then
                echo "当前已是 $target"
            else
                lib cdn-set-ip "$BASE_CONFIG" "$target"
                echo "已更新: $_cdn_current_ip → $target"
            fi
            exit 0
        fi
        if [ "$action" = "test" ]; then
            target="${3:-$_cdn_current_ip}"
            target=$(resolve_cdn_target "$target")
            if [ -z "$target" ]; then
                echo "无目标 IP，用法: sb cdn test [IP|序号]"
                exit 1
            fi
            echo "测试 $target (5 次 TCP 握手)..."
            if [ -x "$CFST" ]; then
                tmp_csv=$(mktemp /tmp/cfst-test.XXXXXX.csv)
                ( cd "$DIR" && "$CFST" -ip "$target" -t 5 -tl 9999 -sl 0 -p 0 -dn 0 -o "$tmp_csv" ) >/dev/null 2>&1
                parsed=0
                while IFS=',' read -r ip sent recv loss delay _; do
                    [ "$ip" = "IP 地址" ] || [ "$ip" = "IP" ] && continue
                    [ -z "$ip" ] && continue
                    printf "  %-18s 发送: %s  接收: %s  丢包: %s  平均: %sms\n" \
                        "$ip" "$sent" "$recv" "$loss" "$delay"
                    parsed=1
                done < "$tmp_csv"
                rm -f "$tmp_csv"
                [ "$parsed" = "0" ] && echo "  $target  全部超时"
            else
                sent=5; recv=0; total_ms=0; min_ms=99999; max_ms=0
                for i in 1 2 3 4 5; do
                    t=$(curl -s -o /dev/null -w "%{time_connect}" \
                        --resolve "$_cdn_domain:443:$target" \
                        --noproxy '*' --connect-timeout 3 --max-time 4 \
                        "https://$_cdn_domain/" 2>/dev/null)
                    ms=$(lib cdn-ms "$t")
                    if [ "${ms:-0}" -gt 0 ] 2>/dev/null; then
                        recv=$((recv + 1))
                        total_ms=$((total_ms + ms))
                        [ "$ms" -lt "$min_ms" ] && min_ms=$ms
                        [ "$ms" -gt "$max_ms" ] && max_ms=$ms
                        printf "  [%d/5] %dms\n" "$i" "$ms"
                    else
                        printf "  [%d/5] 超时\n" "$i"
                    fi
                done
                if [ "$recv" -gt 0 ]; then
                    avg=$((total_ms / recv))
                    loss=$(( (sent - recv) * 100 / sent ))
                    printf "%-18s 发送: %d  接收: %d  丢包: %d%%  平均: %dms  (最小: %dms  最大: %dms)\n" \
                        "$target" "$sent" "$recv" "$loss" "$avg" "$min_ms" "$max_ms"
                else
                    printf "%-18s 全部超时 (5/5)\n" "$target"
                fi
            fi
            exit 0
        fi
        echo "CDN IP: $_cdn_current_ip  域名: $_cdn_domain"
        echo "用法: sb cdn [ip|list|set|test|install]"
        echo "  ip             测试 Cloudflare IP 并保存可用列表"
        echo "  list           查看已保存的可用 IP"
        echo "  set <IP|N>     切换到指定 IP 或第 N 个（序号来自 list）"
        echo "  test [IP|N]    测试当前或指定 IP 延迟（5 次 TCP 握手）"
        echo "  install        安装 CloudflareSpeedTest（测更多 IP，更精准）"
        echo ""
        echo "启用 CDN 中转: sb select proxy-cdn"
        [ -x "$CFST" ] && echo "[cfst 已安装]" || echo "[cfst 未安装，使用 curl 基础测速]"
        exit 0
        ;;
    check)
        target="${2:-}"
        if [ -z "$target" ]; then
            target=$(lib check-vps-ips "$BASE_CONFIG")
            if [ -z "$target" ]; then
                echo "未找到 VPS IP，请指定: sb check <IP>"
                exit 1
            fi
        fi
        for ip in $target; do
            echo "检测 $ip ..."
            lib check-ports "$ip"
        done
        exit 0
        ;;
    update)
        CURL_PROXY=$(curl_proxy_arg)
        if [ -n "$CURL_PROXY" ]; then
            echo "更新规则集（通过代理）..."
        else
            echo "更新规则集（直连，sing-box 未运行）..."
        fi
        RULESET_DIR="$DIR/ruleset"
        mkdir -p "$RULESET_DIR"
        GEOSITE_BASE="https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set"
        GEOIP_BASE="https://raw.githubusercontent.com/SagerNet/sing-geoip/rule-set"
        count_rules() {
            local tmp_json
            tmp_json=$(mktemp)
            if sing-box rule-set decompile -o "$tmp_json" "$1" 2>/dev/null; then
                lib count-rules "$tmp_json"
            else
                echo "?"
            fi
            rm -f "$tmp_json"
        }
        TMP_DIR=$(mktemp -d)
        cleanup_update() { rm -rf "$TMP_DIR"; }
        trap cleanup_update EXIT
        failed=0
        ALL_FILES=$(lib update-ruleset-list)
        for f in $ALL_FILES; do
            printf "  %-35s" "$f"
            case "$f" in
                geoip-*) url="$GEOIP_BASE/$f.srs" ;;
                *)       url="$GEOSITE_BASE/$f.srs" ;;
            esac
            if curl $CURL_PROXY -fLo "$TMP_DIR/$f.srs" "$url" 2>/dev/null; then
                old="?"
                [ -f "$RULESET_DIR/$f.srs" ] && old=$(count_rules "$RULESET_DIR/$f.srs")
                new=$(count_rules "$TMP_DIR/$f.srs")
                echo "$old → $new"
            else
                echo "失败"; failed=1
            fi
        done
        if [ "$failed" -eq 0 ]; then
            mv "$TMP_DIR"/*.srs "$RULESET_DIR/"
            echo "全部更新完成"
        else
            echo "部分文件更新失败，请检查网络（已有文件未被修改）"
            exit 1
        fi
        exit 0
        ;;
    export)
        profile=""
        sub_url=""
        shift  # 跳过 "export"
        while [ $# -gt 0 ]; do
            case "$1" in
                --sub) sub_url="${2:-}"; shift 2 ;;
                *) profile="$1"; shift ;;
            esac
        done
        if [ -n "$profile" ]; then
            base="$DIR/config-${profile}.json"
            out="$DIR/export-${profile}.json"
        else
            base="$BASE_CONFIG"
            out="$DIR/export.json"
        fi
        if [ ! -f "$base" ]; then
            echo "Error: $(basename "$base") 不存在"
            exit 1
        fi
        if [ -n "$sub_url" ]; then
            "$0" sub "$sub_url"
        fi
        lib export-ios "$base" "$out" "$DIR" "$sub_url"
        echo "iPhone 配置已生成: $(basename "$out")"
        exit 0
        ;;
    serve)
        profile="${2:-}"
        if [ -n "$profile" ]; then
            export_file="export-${profile}.json"
        else
            export_file="export.json"
        fi
        if [ ! -f "$DIR/$export_file" ]; then
            echo "Error: $export_file 不存在，请先运行 sb export"
            exit 1
        fi
        local_ip=$(ipconfig getifaddr en0 2>/dev/null || ipconfig getifaddr en1 2>/dev/null)
        port=9000
        while lsof -i :"$port" -sTCP:LISTEN >/dev/null 2>&1; do
            port=$((port + 1))
        done
        echo ""
        echo "iPhone 配置地址:"
        echo "  http://${local_ip}:${port}/${export_file}"
        echo ""
        echo "在 SFI 中: Profiles → New Profile → Type: Remote → 粘贴上面的 URL"
        echo "拉取完成后按 Ctrl+C 关闭"
        echo ""
        node -e "
const http = require('http');
const fs = require('fs');
const file = '$DIR/${export_file}';
http.createServer((req, res) => {
  if (req.url === '/${export_file}') {
    const data = fs.readFileSync(file);
    res.writeHead(200, {
      'Content-Type': 'application/json',
      'Content-Length': data.length
    });
    res.end(data);
  } else {
    res.writeHead(404); res.end('Not Found');
  }
}).listen(${port}, '0.0.0.0', () => console.log('服务已启动'));"
        exit 0
        ;;
    sub)
        sub_url="${2:-}"
        sub_name="${3:-}"
        if [ -z "$sub_url" ]; then
            echo "用法: sb sub <订阅URL> [name]"
            exit 1
        fi
        lib sub-parse "$sub_url" "$(curl_proxy_arg)" "$DIR" "$sub_name"
        exit 0
        ;;
    select)
        lib select-node "$BASE_CONFIG" "${2:-}"
        exit 0
        ;;
    mixed|tun|claude)
        ;;
    *)
        echo "用法: sb [-c config_file] [init|import|mixed|tun|claude|stop|status|log|cdn|check|update|export|serve|sub|select]"
        echo ""
        echo "  init [profile] 从模板 + .env 生成配置（如 sb init dmit）"
        echo "  import [name]  从 VPS 提取 s-ui 凭据到 .env[.name]"
        echo "  -c file        指定配置文件（默认 config.json）"
        echo "  mixed  (默认) 绕过大陆IP，系统代理 127.0.0.1:${PROXY_PORT:-?}"
        echo "  tun            绕过大陆IP，TUN 全局接管（需要 root）"
        echo "  claude         仅 Claude 域名走代理，其余直连（公司网络用）"
        echo "  export [name]  生成 iPhone sing-box 配置（如 sb export dmit）"
        echo "  serve [name]   导出并起临时 HTTP 服务供 iPhone 拉取"
        echo "  sub <url> [name]  订阅转换（有 name 则生成 config-<name>.json）"
        echo "  select [tag]   列出/切换 selector 节点（配合 -c 使用）"
        echo "  stop           停止 sing-box"
        echo "  status         查看运行状态"
        echo "  log [level]    切换日志级别（info/warn/error/debug），运行中自动重启"
        echo "  cdn [ip|list|set|test]  优选 / 切换 Cloudflare IP（启用中转用 sb select proxy-cdn）"
        echo "  check [IP]     检测 IP 是否被封（默认使用配置中的 VPS IP）"
        echo "  update         更新规则集（geosite/geoip）"
        exit 1
        ;;
esac

# 如果已在运行，先停掉
if is_running; then
    old_mode=$(current_mode)
    echo "切换: ${old_mode:-unknown} → $CMD"
    mode_is_proxy && disable_system_proxy
    stop_singbox
    sleep 0.5
fi

# 根据模式生成运行时配置
lib build-run-config "$BASE_CONFIG" "$RUN_CONFIG" "$DIR" "$CMD" "${DEFAULT_IFACE:-}"

echo "启动 sing-box ($CMD 模式)..."
echo "$CMD" > "$MODE_FILE"

if [ "$CMD" = "tun" ]; then
    sudo -v || { echo "需要 sudo 权限"; exit 1; }
    sudo sing-box run -c "$RUN_CONFIG" -D "$DIR" &
else
    sing-box run -c "$RUN_CONFIG" -D "$DIR" &
fi

# 等待 sing-box 进程出现，获取真实 PID（用 -x 精确匹配进程名，避免匹配到 sudo 父进程）
sleep 1
sb_pid=$(sing_box_pid)
if [ -n "$sb_pid" ]; then
    echo "$sb_pid" > "$PID_FILE"
else
    echo $! > "$PID_FILE"
    sb_pid=$!
fi

if pid_alive "$sb_pid"; then
    echo "sing-box 已启动 (PID $sb_pid)"
    mode_is_proxy && enable_system_proxy
else
    echo "启动失败，查看日志排查"
    rm -f "$PID_FILE" "$MODE_FILE"
    exit 1
fi

# 前台等待，Ctrl+C 退出时自动清理
cleanup() {
    mode_is_proxy && disable_system_proxy
    stop_singbox
    rm -f "$MODE_FILE"
    echo "已停止"
    exit 0
}
trap cleanup INT TERM

# wait 只能等待当前 shell 的子进程；TUN 模式下 sing-box 是 sudo 的子进程
# 捕获 PID 一次，避免循环中重复 cat PID 文件
_wait_pid="$sb_pid"
while pid_alive "$_wait_pid"; do
    sleep 1
done
