            ob['transport'] = {'type': 'grpc', 'service_name': grpc_opts.get('grpc-service-name', '')}
        return ob
    elif ptype == 'vless':
        ob = {**base, 'type': 'vless', 'uuid': p.get('uuid', '')}
        if p.get('flow'):
