def parse_clash_proxy(p):
    """Clash YAML proxy → sing-box outbound"""
    ptype = p.get('type', '')
    base = {'tag': p.get('name', ''), 'server': p.get('server', ''),
            'server_port': int(p.get('port', 0))}
    if ptype == 'ss':
        return {**base, 'type': 'shadowsocks',
                'method': p.get('cipher', ''), 'password': str(p.get('password', ''))}
    elif ptype == 'vmess':
