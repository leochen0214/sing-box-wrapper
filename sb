#!/bin/bash
# sb - sing-box 模式切换启动器
# 用法：sb [-c config_file] [mixed|tun|claude|stop|status|update]
#
#   mixed  (默认) - 绕过大陆IP，系统代理 127.0.0.1:<port>（端口从 config.json 读取）
#   tun            - 绕过大陆IP，TUN 全局接管（需要 root）
#   claude         - 仅 Claude 域名走代理，其余直连（公司网络用）

set -euo pipefail

# 跟随 symlink 解析真实脚本目录
_SELF="$0"
if [ -L "$_SELF" ]; then
    _TARGET="$(readlink "$_SELF")"
    [[ "$_TARGET" != /* ]] && _TARGET="$(dirname "$_SELF")/$_TARGET"
    _SELF="$_TARGET"
fi
DIR="$(cd "$(dirname "$_SELF")" && pwd)"
BASE_CONFIG="$DIR/config.json"
RUN_CONFIG="$DIR/.config-run.json"
PID_FILE="$DIR/.sing-box.pid"
MODE_FILE="$DIR/.current-mode"
CLAUDE_DOMAINS_FILE="$DIR/proxy-domains.txt"
CORP_BYPASS_FILE="$DIR/corp-bypass-domains.txt"

# 解析 -c 参数（指定配置文件）
_CONFIG_FLAG=()
while getopts "c:" opt; do
    case $opt in
        c)
            if [[ "$OPTARG" = /* ]]; then
                BASE_CONFIG="$OPTARG"
            else
                BASE_CONFIG="$PWD/$OPTARG"
            fi
            _CONFIG_FLAG=("-c" "$BASE_CONFIG")
            ;;
        *) echo "用法: sb [-c config_file] [command]"; exit 1 ;;
    esac
done
shift $((OPTIND - 1))

# 配置文件不存在时提示 init（init 命令本身不需要 config.json）
if [ ! -f "$BASE_CONFIG" ] && [ "${1:-}" != "init" ] && [ "${1:-}" != "import" ]; then
    if [ -f "$DIR/config.template.json" ]; then
        echo "Error: $(basename "$BASE_CONFIG") 不存在"
        echo "运行 'sb init' 从模板生成配置"
        exit 1
    else
        echo "Error: $(basename "$BASE_CONFIG") 不存在"
        exit 1
    fi
fi

# init/import 不需要读取配置和端口信息
if [ "${1:-}" != "init" ] && [ "${1:-}" != "import" ]; then
    # 从配置文件读取 mixed 入站端口（唯一配置源）
    PROXY_PORT=$(awk '/"type": "mixed"/{found=1} found && /listen_port/{gsub(/[^0-9]/,""); print; exit}' "$BASE_CONFIG")
    # 检测默认网络接口（比 sing-box auto_detect_interface 更可靠）
    DEFAULT_IFACE=$(route -n get default 2>/dev/null | awk '/interface:/{print $2}')
    [ ${#_CONFIG_FLAG[@]} -gt 0 ] && echo "配置文件: $(basename "$BASE_CONFIG")"
    [ -n "$PROXY_PORT" ] && echo "代理端口: $PROXY_PORT, 默认接口: $DEFAULT_IFACE"
fi

enable_system_proxy() {
    networksetup -setwebproxy Wi-Fi 127.0.0.1 "$PROXY_PORT"
    networksetup -setsecurewebproxy Wi-Fi 127.0.0.1 "$PROXY_PORT"
    # 公司域名绕过代理，避免安全监控看到 sing-box 请求公司服务
    if [ -f "$CORP_BYPASS_FILE" ]; then
        local -a domains_arr
        mapfile -t domains_arr < <(grep -v '^#' "$CORP_BYPASS_FILE" | grep -v '^$')
        if [ ${#domains_arr[@]} -gt 0 ]; then
            networksetup -setproxybypassdomains Wi-Fi "${domains_arr[@]}"
        fi
    fi
    echo "系统代理已开启 (127.0.0.1:$PROXY_PORT)"
}

disable_system_proxy() {
    networksetup -setwebproxystate Wi-Fi off
    networksetup -setsecurewebproxystate Wi-Fi off
    networksetup -setproxybypassdomains Wi-Fi ""
    echo "系统代理已关闭"
}

stop_singbox() {
    local is_tun=false
    [ -f "$MODE_FILE" ] && [ "$(cat "$MODE_FILE")" = "tun" ] && is_tun=true

    if [ -f "$PID_FILE" ]; then
        local pid
        pid=$(cat "$PID_FILE")
        if kill -0 "$pid" 2>/dev/null; then
            echo "停止 sing-box (PID $pid)..."
            if $is_tun; then
                sudo kill "$pid" 2>/dev/null || true
            else
                kill "$pid" 2>/dev/null || true
            fi
            # 等待进程退出
            for i in $(seq 1 10); do
                kill -0 "$pid" 2>/dev/null || break
                sleep 0.3
            done
        fi
        rm -f "$PID_FILE"
    fi
    # 兜底：清理残留进程
    pkill -f "sing-box run -c $RUN_CONFIG" 2>/dev/null || true
    $is_tun && sudo pkill -f "sing-box run -c $RUN_CONFIG" 2>/dev/null || true
}

show_status() {
    if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        local mode="unknown"
        [ -f "$MODE_FILE" ] && mode=$(cat "$MODE_FILE")
        echo "sing-box 运行中 (PID $(cat "$PID_FILE"), 模式: $mode)"
    else
        echo "sing-box 未运行"
        rm -f "$PID_FILE"
    fi
    return 0
}

CMD="${1:-mixed}"

# sb init 子命令：从模板 + .env 生成 config.json
_sb_init() {
    local profile="${1:-}"
    local env_file tpl out

    if [ -n "$profile" ]; then
        env_file="$PWD/.env.${profile}"
        out="$PWD/config-${profile}.json"
    else
        env_file="$PWD/.env"
        out="$PWD/config.json"
    fi
    tpl="$DIR/config.template.json"

    if [ ! -f "$env_file" ]; then
        echo "Error: $env_file 不存在"
        echo "可用的 .env 文件："
        ls -1 "$DIR"/.env.* 2>/dev/null | sed 's/.*\/.env\./  sb init /'
        exit 1
    fi
    if [ ! -f "$tpl" ]; then
        echo "Error: 模板 $tpl 不存在"
        exit 1
    fi

    # 读取 .env，替换 ${VAR}，CDN_UUID 不存在时 fallback 到 VLESS_UUID
    python3 - "$env_file" "$tpl" "$out" << 'INIT_EOF'
import sys, re, json

env_file, tpl_file, out_file = sys.argv[1], sys.argv[2], sys.argv[3]

# 解析 .env
env = {}
with open(env_file) as f:
    for line in f:
        line = line.strip()
        if not line or line.startswith('#'):
            continue
        key, _, value = line.partition('=')
        env[key.strip()] = value.strip()

# CDN_UUID fallback 到 VLESS_UUID
if 'CDN_UUID' not in env or not env['CDN_UUID']:
    env['CDN_UUID'] = env.get('VLESS_UUID', '')

# 读取模板并替换 ${VAR}
with open(tpl_file) as f:
    content = f.read()

def replace_var(m):
    key = m.group(1)
    if key not in env:
        print(f"  Warning: ${{{key}}} 未在 .env 中定义", file=sys.stderr)
        return m.group(0)
    return env[key]

content = re.sub(r'\$\{(\w+)\}', replace_var, content)

# 解析为 JSON 对象处理
config = json.loads(content)

# 如果 shadowtls 密码为空，移除相关 outbound 并简化 proxy
ss_pw = env.get('SS_CLIENT_PASSWORD', '')
if not ss_pw:
    remove_tags = {'proxy', 'proxy-shadowtls', 'shadowtls-out', 'proxy-reality'}
    # 先移除所有相关 outbound
    kept = [ob for ob in config['outbounds'] if ob.get('tag') not in remove_tags]
    # 找 reality outbound，改 tag 为 proxy，插到最前面
    reality = next((ob for ob in config['outbounds'] if ob.get('tag') == 'proxy-reality'), None)
    if reality:
        reality['tag'] = 'proxy'
        kept.insert(0, reality)
    config['outbounds'] = kept

with open(out_file, 'w') as f:
    json.dump(config, f, indent=2, ensure_ascii=False)
INIT_EOF

    # 验证生成的配置
    if sing-box check -c "$out" 2>/dev/null; then
        echo "$(basename "$out") 已生成（配置验证通过）"
    else
        echo "$(basename "$out") 已生成，但配置验证失败："
        sing-box check -c "$out" 2>&1
        exit 1
    fi
}

case "$CMD" in
    init)
        _sb_init "${2:-}"
        exit 0
        ;;
    import)
        profile="${2:-}"
        # 解析 --ssh 参数位置
        ssh_host=""
        if [ -n "$profile" ] && [ "${3:-}" = "--ssh" ]; then
            ssh_host="${4:-}"
        elif [ "${2:-}" = "--ssh" ]; then
            ssh_host="${3:-}"
            profile=""
        fi
        # 确定 env 文件（当前工作目录）
        if [ -n "$profile" ]; then
            env_file="$PWD/.env.${profile}"
        else
            env_file="$PWD/.env"
        fi
        if [ ! -f "$env_file" ]; then
            if [ -n "$ssh_host" ]; then
                # --ssh 模式：自动创建 env 文件，从 SSH config 解析 VPS_IP
                vps_ip=$(ssh -G "$ssh_host" 2>/dev/null | awk '/^hostname /{print $2}')
                [ -z "$vps_ip" ] && vps_ip="$ssh_host"
                echo "自动创建 $env_file (VPS_IP=$vps_ip)"
                echo "VPS_IP=${vps_ip}" > "$env_file"
            else
                echo "Error: $env_file 不存在，请先创建并填写 VPS_IP"
                echo ""
                echo "用法: sb import [name] [--ssh <alias>]"
                echo "  sb import              # 读取 .env 中的 VPS_IP"
                echo "  sb import dmit         # 读取 .env.dmit 中的 VPS_IP"
                echo "  sb import --ssh dmit   # 读取 .env，用 SSH alias 连接"
                exit 1
            fi
        fi
        # 读取 VPS_IP
        vps_ip=$(grep '^VPS_IP=' "$env_file" | head -1 | cut -d= -f2)
        if [ -z "$vps_ip" ] && [ -n "$ssh_host" ]; then
            vps_ip=$(ssh -G "$ssh_host" 2>/dev/null | awk '/^hostname /{print $2}')
            [ -z "$vps_ip" ] && vps_ip="$ssh_host"
        elif [ -z "$vps_ip" ]; then
            echo "Error: $env_file 中未找到 VPS_IP"
            exit 1
        fi
        # 确定 SSH 连接目标
        if [ -n "$ssh_host" ]; then
            ssh_target="$ssh_host"
        else
            ssh_target="root@$vps_ip"
        fi
        echo "从 $ssh_target 提取 s-ui 凭据..."
        # 写远程脚本到临时文件，通过 ssh stdin 传递
        _import_tmp=$(mktemp)
        cat > "$_import_tmp" << 'PYEOF'
import sqlite3, json, sys
db = "/usr/local/s-ui/db/s-ui.db"
conn = sqlite3.connect(db)
result = {}
row = conn.execute("SELECT config FROM clients LIMIT 1").fetchone()
if row and row[0]:
    client = json.loads(row[0])
    result["VLESS_UUID"] = client.get("vless", {}).get("uuid", "")
    result["SHADOWTLS_PASSWORD"] = client.get("shadowtls", {}).get("password", "")
    ss_client = client.get("shadowsocks16", {}).get("password", "")
    if ss_client:
        result["SS_CLIENT_PASSWORD"] = f"{ss_client}:{ss_client}"
for row in conn.execute("SELECT tag, out_json, options FROM inbounds"):
    tag, out_json_raw, options_raw = row
    out_json = json.loads(out_json_raw) if out_json_raw else {}
    options = json.loads(options_raw) if options_raw else {}
    if tag == "vless-reality":
        tls = out_json.get("tls", {})
        reality = tls.get("reality", {})
        result["REALITY_PUBLIC_KEY"] = reality.get("public_key", "")
        result["REALITY_SHORT_ID"] = reality.get("short_id", "")
        result["REALITY_SNI"] = tls.get("server_name", "")
    elif tag == "shadowtls-in":
        result["SHADOWTLS_SNI"] = options.get("handshake", {}).get("server", "")
    elif tag == "vless-ws-in":
        result["CDN_DOMAIN"] = out_json.get("tls", {}).get("server_name", "")
conn.close()
# 缺失字段给默认值
result.setdefault("SHADOWTLS_SNI", "")
result.setdefault("CDN_DOMAIN", "")
for k, v in result.items():
    print(f"{k}={v}")
PYEOF
        credentials=$(ssh "$ssh_target" "python3 -" < "$_import_tmp")
        rm -f "$_import_tmp"
        if [ $? -ne 0 ]; then
            echo "Error: SSH 连接或数据库读取失败"
            exit 1
        fi
        # 保留原有 CDN_IP 和 CDN_DOMAIN（如果提取结果为空）
        cdn_ip=$(grep '^CDN_IP=' "$env_file" 2>/dev/null | head -1 | cut -d= -f2 || true)
        cdn_ip="${cdn_ip:-141.101.114.1}"
        existing_cdn_domain=$(grep '^CDN_DOMAIN=' "$env_file" 2>/dev/null | head -1 | cut -d= -f2 || true)
        # 从提取结果中读取 CDN_DOMAIN，为空则用已有值
        extracted_cdn_domain=$(echo "$credentials" | grep '^CDN_DOMAIN=' | head -1 | cut -d= -f2)
        cdn_domain="${extracted_cdn_domain:-$existing_cdn_domain}"
        # 移除 credentials 中的 CDN_DOMAIN（后面单独写入）
        credentials=$(echo "$credentials" | grep -v '^CDN_DOMAIN=')
        {
            echo "# ${profile} VPS (${vps_ip})"
            echo "VPS_IP=${vps_ip}"
            echo "$credentials"
            echo "CDN_IP=${cdn_ip}"
            echo "CDN_DOMAIN=${cdn_domain}"
        } > "$env_file"
        echo ""
        echo "已写入 $env_file:"
        cat "$env_file" | sed 's/^/  /'
        echo ""
        echo "下一步: sb init${profile:+ $profile}"
        exit 0
        ;;
    stop)
        # mixed/claude 模式关闭系统代理
        if [ -f "$MODE_FILE" ]; then
            m=$(cat "$MODE_FILE")
            [ "$m" = "mixed" ] || [ "$m" = "claude" ] && disable_system_proxy
        fi
        stop_singbox
        rm -f "$MODE_FILE"
        echo "已停止"
        exit 0
        ;;
    status)
        show_status
        exit 0
        ;;
    log)
        level="${2:-}"
        if [ "$level" != "info" ] && [ "$level" != "warn" ] && [ "$level" != "error" ] && [ "$level" != "debug" ]; then
            # 无参数时显示当前级别
            current=$(python3 -c "import json; print(json.load(open('$BASE_CONFIG'))['log']['level'])")
            echo "当前日志级别: $current"
            echo "用法: sb log [info|warn|error|debug]"
            exit 0
        fi
        python3 -c "
import json
with open('$BASE_CONFIG') as f:
    c = json.load(f)
c['log']['level'] = '$level'
with open('$BASE_CONFIG', 'w') as f:
    json.dump(c, f, indent=2, ensure_ascii=False)
"
        echo "日志级别已改为: $level"
        # 如果 sing-box 正在运行，自动重启当前模式
        if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null && [ -f "$MODE_FILE" ]; then
            mode=$(cat "$MODE_FILE")
            echo "重启 $mode 模式以生效..."
            exec "$0" "${_CONFIG_FLAG[@]}" "$mode"
        else
            echo "sing-box 未运行，下次启动时生效"
        fi
        exit 0
        ;;
    cdn)
        action="${2:-}"
        CDN_IPS_FILE="$DIR/cdn-ips.txt"
        # 读取当前 proxy-cdn IP
        _cdn_current_ip=$(python3 -c "
import json
with open('$BASE_CONFIG') as f:
    c = json.load(f)
for ob in c['outbounds']:
    if ob.get('tag') == 'proxy-cdn':
        print(ob['server']); break
")
        # 更新 proxy-cdn IP
        _cdn_set_ip() {
            python3 -c "
import json
with open('$BASE_CONFIG') as f:
    c = json.load(f)
for ob in c['outbounds']:
    if ob.get('tag') == 'proxy-cdn':
        ob['server'] = '$1'
        break
with open('$BASE_CONFIG', 'w') as f:
    json.dump(c, f, indent=2, ensure_ascii=False)
"
        }
        # 获取 Cloudflare IP 列表
        _cdn_fetch_ips() {
            local ips
            ips=$(curl -s --noproxy '*' --max-time 5 https://www.cloudflare.com/ips-v4 2>/dev/null \
                | grep -Eo '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+/[0-9]+' \
                | python3 -c "
import sys, ipaddress
ips = []
for line in sys.stdin:
    net = ipaddress.ip_network(line.strip())
    ips.append(str(net.network_address + 1))
print(' '.join(ips))
" 2>/dev/null)
            if [ -z "$ips" ]; then
                echo "104.16.0.1 141.101.114.1 162.159.0.1 172.67.0.1 103.21.244.1 108.162.192.1 173.245.48.1 188.114.96.1 190.93.240.1 198.41.128.1"
            else
                echo "$ips"
            fi
        }
        # 测试单个 IP 的 WebSocket 连通性，输出 "HTTP状态码 耗时秒"
        _cdn_test_ip() {
            curl -s -o /dev/null -w "%{http_code} %{time_total}" \
                --resolve "nongliba.cc:443:$1" \
                --noproxy '*' --max-time 5 \
                -H "Upgrade: websocket" -H "Connection: Upgrade" \
                -H "Sec-WebSocket-Key: dGhlIHNhbXBsZSBub25jZQ==" \
                -H "Sec-WebSocket-Version: 13" \
                https://nongliba.cc/ws 2>/dev/null || echo "000 99.000"
        }
        # 并行测试所有 IP，结果保存到 cdn-ips.txt，最优 IP 写入 stdout
        _cdn_test_all() {
            local cf_ips tmp_dir
            echo "获取 Cloudflare IP 列表..." >&2
            cf_ips=$(_cdn_fetch_ips)
            # 确保当前 IP 在测试列表中
            case " $cf_ips " in
                *" $_cdn_current_ip "*) ;;
                *) cf_ips="$_cdn_current_ip $cf_ips" ;;
            esac
            echo "测试 $(echo $cf_ips | wc -w | tr -d ' ') 个 IP 延迟..." >&2
            tmp_dir=$(mktemp -d)
            for ip in $cf_ips; do
                ( _cdn_test_ip "$ip" > "$tmp_dir/$ip" ) &
            done
            wait
            > "$CDN_IPS_FILE"
            local best_ip="" best_ms=99999
            for ip in $cf_ips; do
                [ -f "$tmp_dir/$ip" ] || continue
                read -r code time < "$tmp_dir/$ip"
                local ms=$(awk "BEGIN{printf \"%d\", $time * 1000}")
                if [ "$code" != "000" ]; then
                    printf "  %-18s ✓  %dms\n" "$ip" "$ms" >&2
                    echo "$ip $ms" >> "$CDN_IPS_FILE"
                    if [ "$ms" -lt "$best_ms" ]; then
                        best_ip="$ip"; best_ms="$ms"
                    fi
                else
                    printf "  %-18s ✗\n" "$ip" >&2
                fi
            done
            rm -rf "$tmp_dir"
            sort -t' ' -k2 -n -o "$CDN_IPS_FILE" "$CDN_IPS_FILE"
            echo "$best_ip $best_ms"
        }
        if [ "$action" = "ip" ]; then
            echo "当前 CDN IP: $_cdn_current_ip"
            result=$(_cdn_test_all)
            best_ip=$(echo "$result" | awk '{print $1}')
            best_ms=$(echo "$result" | awk '{print $2}')
            if [ -z "$best_ip" ]; then
                echo "所有 IP 均不可用"
                exit 1
            fi
            count=$(wc -l < "$CDN_IPS_FILE" | tr -d ' ')
            echo "已保存 $count 个可用 IP → cdn-ips.txt"
            # 与当前 IP 对比
            cur_ms=$(awk -v ip="$_cdn_current_ip" '$1==ip{print $2}' "$CDN_IPS_FILE")
            if [ -z "$cur_ms" ]; then
                echo "当前 $_cdn_current_ip 不可用！"
                _cdn_set_ip "$best_ip"
                echo "已切换: $_cdn_current_ip → $best_ip (${best_ms}ms)"
            elif [ "$best_ip" = "$_cdn_current_ip" ]; then
                echo "当前 $_cdn_current_ip 已是最优 (${cur_ms}ms)"
            else
                echo "当前: $_cdn_current_ip (${cur_ms}ms)  最优: $best_ip (${best_ms}ms)"
            fi
            exit 0
        fi
        if [ "$action" = "list" ]; then
            if [ ! -f "$CDN_IPS_FILE" ] || [ ! -s "$CDN_IPS_FILE" ]; then
                echo "无保存的 IP，先运行: sb cdn ip"
                exit 1
            fi
            echo "当前: $_cdn_current_ip"
            echo "可用 IP（按延迟排序）:"
            i=1
            while read -r ip ms; do
                mark=""
                [ "$ip" = "$_cdn_current_ip" ] && mark=" ←"
                printf "  %d) %-18s %sms%s\n" "$i" "$ip" "$ms" "$mark"
                i=$((i + 1))
            done < "$CDN_IPS_FILE"
            exit 0
        fi
        if [ "$action" = "set" ]; then
            target="${3:-}"
            if [ -z "$target" ]; then
                echo "用法: sb cdn set <IP 或序号>"
                exit 1
            fi
            # 支持序号（从 cdn-ips.txt 选取）
            if echo "$target" | grep -qE '^[0-9]+$' && [ "$target" -le 99 ] 2>/dev/null; then
                if [ -f "$CDN_IPS_FILE" ] && [ -s "$CDN_IPS_FILE" ]; then
                    line=$(sed -n "${target}p" "$CDN_IPS_FILE")
                    if [ -n "$line" ]; then
                        target=$(echo "$line" | awk '{print $1}')
                    fi
                fi
            fi
            if [ "$target" = "$_cdn_current_ip" ]; then
                echo "当前已是 $target"
            else
                _cdn_set_ip "$target"
                echo "已更新: $_cdn_current_ip → $target"
            fi
            exit 0
        fi
        if [ "$action" != "on" ] && [ "$action" != "off" ]; then
            current=$(python3 -c "
import json
with open('$BASE_CONFIG') as f:
    c = json.load(f)
print('on' if c.get('_cdn_enabled') else 'off')
")
            echo "CDN 中转: $current  IP: $_cdn_current_ip"
            echo "用法: sb cdn [on|off|ip|list|set]"
            echo "  on/off    CDN 中转开关"
            echo "  ip        测试所有 Cloudflare IP 并保存可用列表"
            echo "  list      查看已保存的可用 IP"
            echo "  set <N>   切换到第 N 个 IP（序号来自 list）"
            exit 0
        fi
        python3 -c "
import json
with open('$BASE_CONFIG') as f:
    c = json.load(f)
if '$action' == 'on':
    c['_cdn_enabled'] = True
else:
    c.pop('_cdn_enabled', None)
with open('$BASE_CONFIG', 'w') as f:
    json.dump(c, f, indent=2, ensure_ascii=False)
"
        if [ "$action" = "on" ]; then echo "CDN 中转已开启"; else echo "CDN 中转已关闭"; fi
        # 如果 sing-box 正在运行，自动重启当前模式
        if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null && [ -f "$MODE_FILE" ]; then
            mode=$(cat "$MODE_FILE")
            echo "重启 $mode 模式以生效..."
            exec "$0" "${_CONFIG_FLAG[@]}" "$mode"
        else
            echo "下次启动时生效"
        fi
        exit 0
        ;;
    check)
        target="${2:-}"
        if [ -z "$target" ]; then
            # 从配置文件提取所有 VPS IP（outbounds 中的 server 字段，排除 CDN IP）
            target=$(python3 -c "
import json
with open('$BASE_CONFIG') as f:
    c = json.load(f)
seen = set()
for ob in c.get('outbounds', []):
